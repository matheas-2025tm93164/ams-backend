# Copy to .env.production (gitignored) and fill before:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# Never commit .env.production.

# Required: at least 32 characters (same rule as user service config)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Required: comma-separated allowed browser origins (no spaces). Example for EC2 demo + local dev:
# CORS_ORIGINS=http://EC2_PUBLIC_IP:5173,http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGINS=https://your-frontend-host.example.com

# Optional: host port mapped to gateway (default 8000)
# GATEWAY_PUBLISH=8000

# Optional: set to 1 to seed demo admin/staff on first startup (turn off after first run in real demos)
SEED_DEMO_USERS=0
